# Database
DATABASE_URL="postgresql://user:password@localhost:5432/hermes_support"

# Storage — Railway Volume (filesystem, no external S3 needed)
# Mount a Railway Volume at /data, then set:
STORAGE_ROOT="/data/photos"

# Base URL for generating photo serve URLs (must match your Railway domain)
NEXT_PUBLIC_BASE_URL="https://your-app.up.railway.app"

# Admin session (set a long random string)
ADMIN_SESSION_SECRET="change-me-to-a-random-secret-at-least-32-chars"

# Cron jobs secret
CRON_SECRET="change-me-to-a-random-cron-secret"

# Node env
NODE_ENV="production"
