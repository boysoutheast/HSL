model MediaLibraryRule {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  name            String
  // Trigger: MIN_COUNT | MAX_AGE_DAYS | NO_WINNER
  triggerType     String    @map("trigger_type")
  threshold       Float // MIN_COUNT: jumlah minimum; MAX_AGE_DAYS: umur hari; NO_WINNER: skor minimum
  // Scope — minimal salah satu diisi
  productId       String?   @map("product_id")
  characterId     String?   @map("character_id")
  mediaType       String    @default("VIDEO") @map("media_type") // IMAGE | VIDEO
  // Action saat trigger: CREATE_TASK | NOTIFY
  actionType      String    @default("CREATE_TASK") @map("action_type")
  taskType        String?   @map("task_type") // GENERATE_VIDEO | GENERATE_PHOTO | CAPTION_ONLY
  taskPayloadJson String?   @map("task_payload_json") // extra params untuk worker
  status          String    @default("ACTIVE") // ACTIVE | PAUSED
  cooldownHours   Int       @default(24) @map("cooldown_hours")
  lastTriggeredAt DateTime? @map("last_triggered_at")
  triggerCount    Int       @default(0) @map("trigger_count")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user      AdminUser  @relation(fields: [userId], references: [id], onDelete: Cascade)
  product   Product?   @relation(fields: [productId], references: [id], onDelete: Cascade)
  character Character? @relation(fields: [characterId], references: [id], onDelete: Cascade)

  @@index([status])
  @@index([userId])
  @@map("media_library_rules")
}

model WorkerTaskResult {
  id            String   @id @default(cuid())
  workerTaskId  String   @map("worker_task_id")
  resultType    String   @map("result_type") // media_asset | content_log | meta_entity | raw
  mediaAssetId  String?  @map("media_asset_id")
  contentLogId  String?  @map("content_log_id")
  dataJson      String?  @map("data_json")
  createdAt     DateTime @default(now()) @map("created_at")

  workerTask WorkerTask  @relation(fields: [workerTaskId], references: [id], onDelete: Cascade)
  mediaAsset MediaAsset? @relation(fields: [mediaAssetId], references: [id], onDelete: SetNull)

  @@index([workerTaskId])
  @@map("worker_task_results")
}

model RuleTemplate {
  id                String   @id @default(cuid())
  userId            String?  @map("user_id") // null = built-in template
  name              String
  description       String?
  scope             String // CAMPAIGN | ADSET | AD
  ruleCategory      String   @map("rule_category") // THRESHOLD | SCHEDULE | COMPOSITE
  conditionTreeJson String   @map("condition_tree_json")
  actionSpecJson    String   @map("action_spec_json")
  isBuiltin         Boolean  @default(false) @map("is_builtin")
  usageCount        Int      @default(0) @map("usage_count")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  user AdminUser? @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("rule_templates")
}

model MetaAudience {
  id              String    @id @default(cuid())
  userId          String    @map("user_id")
  metaAdAccountId String    @map("meta_ad_account_id") // FK meta_ad_accounts.id
  metaAudienceId  String?   @map("meta_audience_id") // ID dari Meta setelah dibuat
  name            String
  type            String // CUSTOM | LOOKALIKE
  subtype         String? // WEBSITE | ENGAGEMENT | CUSTOMER_LIST | VIDEO | LOOKALIKE
  description     String?
  // Lookalike params
  sourceAudienceId String?  @map("source_audience_id") // FK meta_audiences.id (self-ref via Meta ID)
  lookalikeRatio   Float?   @map("lookalike_ratio") // 0.01 - 0.20
  lookalikeCountry String?  @map("lookalike_country") // ID, US, dll
  // Custom audience rule (website events etc)
  ruleJson        String?   @map("rule_json")
  retentionDays   Int?      @map("retention_days")
  // Status & size
  status          String    @default("DRAFT") // DRAFT | CREATING | READY | FAILED | DELETED
  sizeLowerBound  Int?      @map("size_lower_bound")
  sizeUpperBound  Int?      @map("size_upper_bound")
  errorMessage    String?   @map("error_message")
  lastSyncedAt    DateTime? @map("last_synced_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([metaAdAccountId])
  @@map("meta_audiences")
}

model MetaCatalog {
  id             String    @id @default(cuid())
  userId         String    @map("user_id")
  metaBusinessId String?   @map("meta_business_id") // FK meta_businesses.id
  metaCatalogId  String?   @map("meta_catalog_id") // ID dari Meta
  name           String
  vertical       String    @default("commerce") // commerce | hotels | flights
  productCount   Int       @default(0) @map("product_count")
  // CPAS
  isCpas         Boolean   @default(false) @map("is_cpas")
  partnerName    String?   @map("partner_name") // e.g. Shopee
  status         String    @default("DRAFT") // DRAFT | CREATING | READY | FAILED
  errorMessage   String?   @map("error_message")
  lastSyncedAt   DateTime? @map("last_synced_at")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  user        AdminUser        @relation(fields: [userId], references: [id], onDelete: Cascade)
  productSets MetaProductSet[]

  @@index([userId])
  @@map("meta_catalogs")
}

model MetaProductSet {
  id               String    @id @default(cuid())
  catalogId        String    @map("catalog_id") // FK meta_catalogs.id
  metaProductSetId String?   @map("meta_product_set_id")
  name             String
  filterJson       String?   @map("filter_json") // Meta product set filter
  productCount     Int       @default(0) @map("product_count")
  status           String    @default("DRAFT") // DRAFT | CREATING | READY | FAILED
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  catalog MetaCatalog @relation(fields: [catalogId], references: [id], onDelete: Cascade)

  @@index([catalogId])
  @@map("meta_product_sets")
}

model CapiEventConfig {
  id                  String    @id @default(cuid())
  userId              String    @map("user_id")
  name                String
  pixelId             String    @map("pixel_id")
  accessTokenEncrypted String   @map("access_token_encrypted") // CAPI system user token
  testEventCode       String?   @map("test_event_code")
  // Event yang diterima endpoint /api/capi/events
  allowedEvents       String[]  @default(["PageView", "ViewContent", "AddToCart", "Purchase", "Lead"]) @map("allowed_events")
  // Optional: link ke landing page untuk auto-stat
  landingPageId       String?   @map("landing_page_id")
  isActive            Boolean   @default(true) @map("is_active")
  eventCount          Int       @default(0) @map("event_count")
  lastEventAt         DateTime? @map("last_event_at")
  lastError           String?   @map("last_error")
  createdAt           DateTime  @default(now()) @map("created_at")
  updatedAt           DateTime  @updatedAt @map("updated_at")

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([pixelId])
  @@map("capi_event_configs")
}

model GeneratedMedia {
  id                 String    @id @default(cuid())
  userId             String?   @map("user_id")
  source             String    @default("hsl-v1")
  model              String    @default("hsl-video-1")
  externalJobId      String?   @unique @map("external_job_id")
  status             String    @default("queued")
  prompt             String
  instagramAccountId String?   @map("instagram_account_id")
  workerTaskId       String?   @map("worker_task_id")
  mediaType          String    @default("VIDEO") @map("media_type")
  creditsCost        Int?      @map("credits_cost")
  videoUrl           String?   @map("video_url")
  thumbnailUrl       String?   @map("thumbnail_url")
  durationSeconds    Int       @default(10) @map("duration_seconds")
  orientation        String    @default("portrait") @map("orientation")
  resolution         String    @default("SD") @map("resolution")
  refundedAt         DateTime? @map("refunded_at")
  rawWebhookJson     String?   @map("raw_webhook_json")
  rawHistoryJson     String?   @map("raw_history_json")
  errorMessage       String?   @map("error_message")
  createdAt          DateTime  @default(now()) @map("created_at")
  completedAt        DateTime? @map("completed_at")

  user              AdminUser?           @relation(fields: [userId], references: [id], onDelete: SetNull)
  instagramAccount  InstagramAccount?    @relation(fields: [instagramAccountId], references: [id], onDelete: SetNull)
  workerTask        WorkerTask?          @relation(fields: [workerTaskId], references: [id], onDelete: SetNull)
  inputs            GeneratedMediaInput[]

  @@map("generated_media")
}

model GeneratedMediaInput {
  id               String @id @default(cuid())
  generatedMediaId String @map("generated_media_id")
  photoReferenceId String @map("photo_reference_id")
  inputOrder       Int    @default(0) @map("input_order")

  generatedMedia GeneratedMedia @relation(fields: [generatedMediaId], references: [id], onDelete: Cascade)
  photoReference PhotoReference @relation(fields: [photoReferenceId], references: [id])

  @@map("generated_media_inputs")
}

model CreditTransaction {
  id               String   @id @default(cuid())
  userId           String   @map("user_id")
  amount           Int      // positive=grant/refund, negative=debit
  reason           String   // "trial_grant" | "video_generation" | "refund" | "admin_grant"
  refId            String?  @map("ref_id") // generatedMediaId or null
  refType          String?  @map("ref_type") // "generated_media" or null
  balanceAfter     Int      @map("balance_after")
  idempotencyKey   String   @unique @map("idempotency_key")
  createdAt        DateTime @default(now()) @map("created_at")

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@map("credit_transactions")
}

model ConversationThread {
  id                String   @id @default(cuid())
  subjectType       String   @map("subject_type")
  subjectId         String?  @map("subject_id")
  status            String   @default("open") @map("status")
  autoContinueCount Int      @default(0) @map("auto_continue_count")
  maxAutoContinue   Int      @default(5) @map("max_auto_continue")
  telegramChatId    String?  @map("telegram_chat_id")
  createdAt         DateTime @default(now()) @map("created_at")
  updatedAt         DateTime @updatedAt @map("updated_at")

  messages ThreadMessage[]

  @@map("conversation_threads")
}

model ThreadMessage {
  id           String   @id @default(cuid())
  threadId     String   @map("thread_id")
  role         String   @map("role")
  kind         String   @default("text") @map("kind")
  content      String   @map("content")
  metadataJson String?  @map("metadata_json")
  eventId      String?  @unique @map("event_id")
  createdAt    DateTime @default(now()) @map("created_at")

  thread ConversationThread @relation(fields: [threadId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@map("thread_messages")
}


model UserApiKey {
  id          String    @id @default(cuid())
  userId      String    @map("user_id")
  keyHash     String    @map("key_hash")
  prefix      String    // first 8 chars for display (hsk_xxxx)
  name        String    @default("Default")
  lastUsedAt  DateTime? @map("last_used_at")
  status      String    @default("active") // active | revoked
  createdAt   DateTime  @default(now()) @map("created_at")

  user        AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@unique([userId, keyHash])
  @@map("user_api_keys")
}

